        <mxCell id="n_press" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" value="Press CSV (Upload icon) &#8594; open &#39;Import from CSV&#39; dialog" vertex="1">
          <mxGeometry height="50" width="250" x="320" y="96" as="geometry" />
        </mxCell>
        <mxCell id="n_pick" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" value="Browse / drag one or more .csv files&lt;br&gt;from the customer&#39;s USB drive (disk-on-key)" vertex="1">
          <mxGeometry height="60" width="270" x="310" y="176" as="geometry" />
        </mxCell>
        <mxCell id="n_read" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" value="Customer&#39;s USB drive (disk-on-key):&lt;br&gt;read the selected .csv file text (FileReader.readAsText)" vertex="1">
          <mxGeometry height="72" width="320" x="1070" y="178" as="geometry" />
        </mxCell>
        <mxCell id="n_parse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" value="parseCsv &#8212; validate the file" vertex="1">
          <mxGeometry height="46" width="300" x="625" y="272" as="geometry" />
        </mxCell>

        <mxCell id="D1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="Header present and at least 1 data row?" vertex="1">
          <mxGeometry height="72" width="220" x="665" y="344" as="geometry" />
        </mxCell>
        <mxCell id="D2" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="Every row has a valid Process?" vertex="1">
          <mxGeometry height="72" width="220" x="665" y="438" as="geometry" />
        </mxCell>
        <mxCell id="D3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="Temperatures 20 to 80 &#176;C? (non-N&#8322;)" vertex="1">
          <mxGeometry height="72" width="220" x="665" y="532" as="geometry" />
        </mxCell>
        <mxCell id="D4" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="Times 1 to 120 min? (Bleaching 720)" vertex="1">
