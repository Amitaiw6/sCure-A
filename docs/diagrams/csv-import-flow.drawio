        </mxCell>
        <mxCell id="D5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="At most 2 N&#8322; purges?" vertex="1">
