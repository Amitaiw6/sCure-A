        </mxCell>
        <mxCell id="D6" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="After each N&#8322;: Cure/Bleaching, then a Cooling (vent)?" vertex="1">
          <mxGeometry height="84" width="256" x="647" y="814" as="geometry" />
        </mxCell>
        <mxCell id="D7" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" value="Temperature never drops without a Cooling step?" vertex="1">
          <mxGeometry height="84" width="256" x="647" y="918" as="geometry" />
        </mxCell>

